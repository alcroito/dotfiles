{{- if .install_packages -}}
{{- if .install_secrets -}}

{{- if eq .chezmoi.os "windows" }}

# Refresh path
$env:Path = [System.Environment]::GetEnvironmentVariable("Path","User"),[System.Environment]::GetEnvironmentVariable("Path","Machine") -join ";"

if (!(Get-Command pass-cli.exe -ErrorAction SilentlyContinue)) {
    Write-Host "Installing Proton Pass CLI"
    
    # Download and run the official Proton Pass CLI installer
    $installerPath = Join-Path $env:TEMP "install_proton_pass_cli.ps1"
    Invoke-WebRequest -Uri https://proton.me/download/pass-cli/install.ps1 -OutFile $installerPath
    
    # Run the installer script
    & $installerPath
    
    # Clean up
    Remove-Item $installerPath -ErrorAction SilentlyContinue
    
    Write-Host "Proton Pass CLI installed successfully"
} else {
    Write-Host "Proton Pass CLI binary already present"
}

# end of windows
{{- end -}}

# end of install_secrets
{{- end -}}

# end of install_packages
{{- end -}}
